# Agent Bar Hangout — Environment Configuration
# Copy this file to .env and fill in values as needed:
#   cp .env.example .env        (Linux/macOS)
#   Copy-Item .env.example .env (PowerShell)

# ── Server ────────────────────────────────────────────────
# Port for the Node.js web-mode server (default: 8080)
# PORT=8080

# ── LLM API Keys (optional) ──────────────────────────────
# Set a default OpenAI key here; other vendors can be
# configured at runtime in the MCP Configuration modal.
OPENAI_API_KEY=your-openai-api-key-here
